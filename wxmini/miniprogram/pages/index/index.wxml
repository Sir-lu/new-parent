<view class="chat-page">
  <!-- 消息滚动区 -->
  <scroll-view class="msg-list" scroll-y scroll-into-view="{{scrollTo}}" scroll-with-animation>
    <!-- 欢迎消息 -->
    <view class="msg-bubble ai" wx:if="{{messages.length === 0}}">
      <view class="bubble-avatar">🧊</view>
      <view class="bubble-card welcome">
        <text class="welcome-title">遇到什么事了？</text>
        <text class="welcome-sub">跟我说说刚才发生了什么，我来帮你分析。</text>
        <text class="welcome-hint">可以先选下面的场景，或者直接说。</text>
      </view>
    </view>

    <!-- 对话消息 -->
    <view wx:for="{{messages}}" wx:key="id">
      <!-- 用户消息 -->
      <view wx:if="{{item.role === 'user'}}" class="msg-bubble user">
        <view class="bubble-card user-card">
          <text class="user-text">{{item.text}}</text>
        </view>
        <view class="user-avatar">{{selectedChild ? (selectedChild.gender === 'boy' ? '👦' : '👧') : '👤'}}</view>
      </view>

      <!-- AI 回复 -->
      <view wx:if="{{item.role === 'ai'}}" class="msg-bubble ai">
        <view class="bubble-avatar">🧊</view>
        <view class="bubble-card ai-card">

          <!-- 加载中 -->
          <view wx:if="{{item.loading}}" class="ai-loading">
            <text class="loading-dot">●</text><text class="loading-dot">●</text><text class="loading-dot">●</text>
          </view>

          <!-- 冷静引导 -->
          <view wx:if="{{!item.loading && item.coolDown}}" class="ai-cooldown">
            <text class="ai-cooldown-icon">🧊</text>
            <text class="ai-cooldown-text">{{item.coolDown}}</text>
          </view>

          <!-- 共情 -->
          <view wx:if="{{!item.loading && item.emotionalCheck}}" class="ai-empathy">
            <text>{{item.emotionalCheck}}</text>
          </view>

          <!-- 沟通话术（核心，放最大） -->
          <view wx:if="{{!item.loading && item.script}}" class="ai-script">
            <text class="ai-script-label">💬 可以这样对孩子说</text>
            <text class="ai-script-text">{{item.script}}</text>
          </view>

          <!-- 展开详细 -->
          <view wx:if="{{!item.loading && !item.showDetail}}" class="ai-more" data-index="{{index}}" bindtap="toggleDetail">
            <text>查看详细分析 →</text>
          </view>

          <!-- 详细内容 -->
          <view wx:if="{{!item.loading && item.showDetail}}" class="ai-detail">
            <view class="ai-detail-item" wx:if="{{item.rootCause}}">
              <text class="detail-label">🔍 根源分析</text>
              <text class="detail-text">{{item.rootCause}}</text>
            </view>
            <view class="ai-detail-item" wx:if="{{item.keyInsight}}">
              <text class="detail-label">💡 一句话本质</text>
              <text class="detail-text">{{item.keyInsight}}</text>
            </view>
            <view wx:if="{{item.steps && item.steps.length > 0}}">
              <text class="detail-label">📋 分步行动</text>
              <view wx:for="{{item.steps}}" wx:key="step" wx:for-item="step" class="ai-step">
                <text class="step-num">{{step.step}}</text>
                <view class="step-body">
                  <text class="step-action">{{step.action}}</text>
                  <text class="step-principle">📖 {{step.principle}}</text>
                </view>
              </view>
            </view>
            <view class="ai-detail-item" wx:if="{{item.methodTags && item.methodTags.length > 0}}">
              <text class="detail-label">🏷️ 用到的方法</text>
              <view class="detail-tags">
                <text wx:for="{{item.methodTags}}" wx:key="*this" wx:for-item="tag" class="detail-tag">{{tag}}</text>
              </view>
            </view>
            <view class="ai-more" data-index="{{index}}" bindtap="toggleDetail">
              <text>收起 ↑</text>
            </view>
          </view>

          <!-- 评分 -->
          <view wx:if="{{!item.loading}}" class="ai-rate">
            <text class="rate-hint">这个建议有帮助吗？</text>
            <view class="rate-stars">
              <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this"
                    class="rate-star {{item.rating >= $index ? 'on' : ''}}"
                    data-index="{{index}}" data-rating="{{$index + 1}}"
                    bindtap="rateMessage">☆</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view id="msg-bottom" style="height:4rpx;"></view>
  </scroll-view>

  <!-- 底部输入区 -->
  <view class="input-bar">
    <!-- 快捷选项行 -->
    <view class="quick-row">
      <scroll-view class="chip-scroll" scroll-x>
        <!-- 场景 chips -->
        <view wx:for="{{allScenes}}" wx:key="id"
              class="quick-chip {{activeScene === item.id ? 'active' : ''}}"
              data-scene="{{item}}"
              bindtap="pickScene">
          {{item.icon}} {{item.name}}
        </view>
      </scroll-view>
      <!-- 孩子 chip -->
      <view class="quick-chip child {{selectedChild ? 'has-child' : ''}}" bindtap="toProfileList">
        {{selectedChild ? selectedChild.icon + ' ' + selectedChild.name : '👤 添加孩子'}}
      </view>
    </view>

    <!-- 输入框 -->
    <view class="input-row">
      <textarea class="chat-input"
             value="{{inputText}}"
             placeholder="说说刚才发生了什么…"
             placeholder-style="color:#B0C4CF; font-size:28rpx;"
             maxlength="1000"
             auto-height
             show-confirm-bar="{{false}}"
             bindinput="onInput"
             bindconfirm="sendMessage"/>
      <view class="send-btn {{inputText ? 'ready' : ''}}" bindtap="sendMessage">
        <text class="send-icon">↑</text>
      </view>
    </view>
  </view>
</view>
