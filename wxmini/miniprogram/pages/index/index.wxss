/*
 * 首页 — 对话式界面（豆包风格）
 * 顶部菜单 + 侧滑历史 + 消息列表 + 底部输入区
 */

/* ===== 页面结构 ===== */
.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: var(--bg-primary);
  position: relative;
}

/* ===== 顶部栏 ===== */
.top-bar {
  flex-shrink: 0;
  background: var(--bg-card);
  border-bottom: 1rpx solid rgba(91, 139, 160, 0.08);
  box-sizing: border-box;
}

.top-bar-inner {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.top-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
}

.top-btn:active { background: var(--bg-soft); }

.menu-icon {
  width: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
}

.menu-line {
  height: 4rpx;
  background: var(--text-primary);
  border-radius: 4rpx;
}

.menu-line.short { width: 70%; }

.top-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.new-icon {
  font-size: 40rpx;
  color: var(--text-primary);
  line-height: 1;
  font-weight: 300;
}

/* ===== 侧滑抽屉 ===== */
.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(38, 58, 74, 0);
  z-index: 100;
  pointer-events: none;
  transition: background 0.28s ease;
}

.drawer-mask.show {
  background: rgba(38, 58, 74, 0.35);
  pointer-events: auto;
}

.drawer {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: 78%;
  max-width: 600rpx;
  background: var(--bg-card);
  z-index: 101;
  display: flex;
  flex-direction: column;
  transform: translateX(-100%);
  transition: transform 0.28s ease;
  box-shadow: 8rpx 0 32rpx rgba(38, 58, 74, 0.12);
  box-sizing: border-box;
}

.drawer.open {
  transform: translateX(0);
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid rgba(91, 139, 160, 0.08);
}

.drawer-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.drawer-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: var(--text-muted);
  line-height: 1;
}

.drawer-list {
  flex: 1;
  min-height: 0;
  padding: 12rpx 0;
}

.drawer-empty {
  text-align: center;
  padding: 80rpx 40rpx;
  font-size: 26rpx;
  color: var(--text-muted);
}

.history-item {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(91, 139, 160, 0.06);
}

.history-item:active {
  background: var(--bg-soft);
}

.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-preview {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-time {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  display: block;
}

.drawer-footer {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx 32rpx calc(28rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(91, 139, 160, 0.08);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.drawer-footer:active { background: var(--bg-soft); }

.drawer-new-icon {
  font-size: 32rpx;
  line-height: 1;
}

/* ===== 消息列表 ===== */
.msg-list {
  flex: 1;
  overflow-y: scroll;
  padding: 20rpx 0 12rpx;
  min-height: 0;
}

/* ===== 消息气泡 ===== */
.msg-bubble {
  display: flex;
  align-items: flex-end;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  animation: msgIn 0.3s var(--ease-out);
}
@keyframes msgIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.msg-bubble.ai {
  justify-content: flex-start;
}
.msg-bubble.user {
  justify-content: flex-end;
}

.bubble-avatar {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: var(--color-primary-ghost);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
  margin-right: 14rpx;
}
.user-avatar {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8EDF2, #D5DFE8);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
  margin-left: 14rpx;
}

/* ===== 气泡卡片 ===== */
.bubble-card {
  flex-shrink: 1;
  max-width: 530rpx;
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
}

/* 欢迎卡片 */
.bubble-card.welcome {
  background: var(--bg-card);
  box-shadow: var(--shadow-card);
  text-align: center;
  padding: 36rpx 32rpx;
  max-width: 560rpx;
}
.welcome-title {
  font-size: 32rpx; font-weight: 700;
  color: var(--text-primary); display: block;
}
.welcome-sub {
  font-size: 26rpx; color: var(--text-secondary);
  margin-top: 10rpx; display: block; line-height: 1.6;
}
.welcome-hint {
  font-size: 22rpx; color: var(--text-muted);
  margin-top: 16rpx; display: block;
}

/* 用户气泡 */
.bubble-card.user-card {
  background: var(--color-primary);
  color: #FFFFFF;
  box-shadow: var(--shadow-button);
  word-break: break-all;
  overflow-wrap: break-word;
}
.user-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #FFFFFF;
  white-space: pre-wrap;
  word-break: break-all;
  display: block;
}

/* AI 气泡 */
.bubble-card.ai-card {
  background: var(--bg-card);
  box-shadow: var(--shadow-card);
  word-break: break-all;
  overflow-wrap: break-word;
}

/* 引导追问 */
.ai-prompt { padding: 8rpx 0; }
.ai-prompt-text {
  font-size: 28rpx; color: var(--text-primary);
  line-height: 1.7; display: block;
}

/* 加载动画 */
.ai-loading {
  display: flex; gap: 6rpx; padding: 8rpx 0;
}
.loading-dot {
  font-size: 20rpx; color: var(--color-primary-light);
  animation: dotBounce 1.2s infinite;
}
.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotBounce {
  0%, 60% { opacity: 0.3; }
  30% { opacity: 1; }
}

/* coolDown 横幅 */
.ai-cooldown {
  background: linear-gradient(135deg, #EBF5FA, #E0F0F6);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  display: flex; gap: 10rpx; align-items: flex-start;
}
.ai-cooldown-icon { font-size: 28rpx; flex-shrink: 0; margin-top: 2rpx; }
.ai-cooldown-text { font-size: 26rpx; color: var(--color-primary-dark); line-height: 1.6; font-weight: 500; }

/* 共情 */
.ai-empathy {
  font-size: 26rpx; color: var(--text-secondary);
  line-height: 1.6; margin-bottom: 16rpx;
}

/* 沟通话术（核心） */
.ai-script {
  background: var(--bg-soft);
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx; margin-bottom: 12rpx;
  border-left: 4rpx solid var(--color-primary);
}
.ai-script-label {
  font-size: 22rpx; color: var(--color-primary);
  font-weight: 600; display: block; margin-bottom: 8rpx;
}
.ai-script-text {
  font-size: 28rpx; color: var(--text-primary);
  line-height: 1.75; display: block;
}

/* 展开更多 */
.ai-more {
  text-align: center; padding: 8rpx 0;
}
.ai-more text { font-size: 24rpx; color: var(--color-primary); }

/* 详细内容 */
.ai-detail {
  margin-top: 16rpx; padding-top: 16rpx;
  border-top: 1rpx solid rgba(91,139,160,0.1);
}
.ai-detail-item { margin-bottom: 16rpx; }
.detail-label {
  font-size: 22rpx; color: var(--text-muted);
  font-weight: 600; display: block; margin-bottom: 6rpx;
}
.detail-text { font-size: 26rpx; color: var(--text-primary); line-height: 1.6; }

.ai-step {
  display: flex; gap: 12rpx; margin-bottom: 12rpx;
  padding: 14rpx 16rpx; background: var(--bg-soft);
  border-radius: var(--radius-sm);
}
.step-num {
  width: 40rpx; height: 40rpx;
  background: var(--color-primary-ghost); color: var(--color-primary-dark);
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 700; flex-shrink: 0;
}
.step-body { flex: 1; }
.step-action { font-size: 26rpx; color: var(--text-primary); line-height: 1.5; display: block; }
.step-principle { font-size: 20rpx; color: var(--text-muted); margin-top: 4rpx; display: block; }
.detail-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.detail-tag {
  font-size: 20rpx; color: var(--color-primary-dark);
  background: var(--color-primary-ghost);
  padding: 4rpx 16rpx; border-radius: 20rpx;
}

/* 评分 */
.ai-rate {
  margin-top: 16rpx; padding-top: 14rpx;
  border-top: 1rpx solid rgba(91,139,160,0.08);
  display: flex; align-items: center; gap: 12rpx;
}
.rate-hint { font-size: 22rpx; color: var(--text-muted); }
.rate-stars { display: flex; gap: 4rpx; }
.rate-star { font-size: 32rpx; color: var(--text-muted); }
.rate-star.on { color: var(--color-sage); }

/* ===== 底部输入区 ===== */
.input-bar {
  flex-shrink: 0;
  padding: 12rpx 24rpx 24rpx;
  background: var(--bg-card);
  border-top: 1rpx solid rgba(91,139,160,0.06);
}

/* 快捷选项行 */
.quick-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 14rpx;
}
.chip-scroll {
  flex: 1;
  white-space: nowrap;
  display: flex;
  gap: 10rpx;
}
.quick-chip {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 20rpx;
  background: var(--bg-soft);
  border-radius: 40rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  border: 2rpx solid transparent;
  transition: all 0.2s;
  flex-shrink: 0;
}
.quick-chip.active {
  background: var(--color-primary-ghost);
  color: var(--color-primary-dark);
  border-color: var(--color-primary-light);
  font-weight: 600;
}

/* 输入行 — 豆包风格：发送按钮嵌在输入条内部 */
.input-row {
  display: flex;
  align-items: flex-end;
  gap: 0;
  background: var(--bg-soft);
  border-radius: 48rpx;
  padding: 10rpx 10rpx 10rpx 24rpx;
  min-height: 80rpx;
  max-height: 360rpx;
}
.chat-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  max-height: 320rpx;
  padding: 10rpx 0;
}
.send-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
  margin-bottom: 2rpx;
  transition: all 0.25s;
}
.send-icon {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}
.send-btn.ready {
  background: var(--color-primary);
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 0;
}
