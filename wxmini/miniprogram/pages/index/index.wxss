/*
 * 首页 — 场景卡片选择
 * 设计：柔和渐变底色，有机圆角，温暖光影
 */

.container {
  padding: 0 32rpx 80rpx;
}

/* ===== Hero ===== */
.hero {
  padding: 48rpx 16rpx 20rpx;
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: "";
  position: absolute;
  bottom: -20rpx; right: -40rpx;
  width: 180rpx; height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212,132,106,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -1rpx;
  line-height: 1.25;
  position: relative;
  z-index: 1;
}
.hero-sub {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  line-height: 1.6;
  position: relative;
  z-index: 1;
}

/* ===== 孩子档案入口 ===== */
.child-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 20rpx 28rpx;
  margin-bottom: 8rpx;
  box-shadow: var(--shadow-card);
  border: 2rpx solid var(--color-primary-light);
  transition: all 0.2s;
}
.child-entry:active {
  transform: scale(0.985);
  border-color: var(--color-primary);
}
.child-entry-left { display: flex; align-items: center; gap: 14rpx; flex: 1; }
.child-entry-icon { font-size: 40rpx; }
.child-entry-text { font-size: 26rpx; color: var(--text-secondary); }
.child-entry-arrow { font-size: 22rpx; color: var(--text-muted); }

/* ===== 语音提示 ===== */
.voice-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, var(--color-primary-ghost) 0%, rgba(184,169,201,0.1) 100%);
  border-radius: var(--radius-md);
}
.voice-tip-icon { font-size: 30rpx; }
.voice-tip-text { font-size: 24rpx; color: var(--color-primary-dark); font-weight: 500; }

/* ===== 分类卡片 ===== */
.category-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  overflow: hidden;
  transition: all 0.25s;
}
.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 32rpx 36rpx;
  border-left: 4rpx solid transparent;
  transition: border-color 0.3s;
}
.category-header:active {
  background: rgba(252,246,240,0.6);
}

.category-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.category-arrow {
  width: 48rpx; height: 48rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--bg-soft);
  border-radius: 50%;
  font-size: 20rpx;
  color: var(--text-muted);
  transition: all 0.3s;
}
.category-arrow.open {
  transform: rotate(180deg);
  background: var(--color-primary-ghost);
  color: var(--color-primary);
}

/* ===== 场景列表 ===== */
.scene-list { display: none; }
.scene-list.show {
  display: block;
  animation: fadeSlideIn 0.3s ease;
}
@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.scene-item {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx 20rpx 36rpx;
  margin: 0 24rpx 6rpx;
  border-radius: var(--radius-md);
  transition: all 0.2s;
}
.scene-item:active {
  background: var(--color-primary-ghost);
  transform: scale(0.98);
}
.scene-icon {
  width: 72rpx; height: 72rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
  background: linear-gradient(135deg, var(--color-primary-ghost) 0%, rgba(248,224,213,0.4) 100%);
  border-radius: var(--radius-md);
  margin-right: 20rpx;
  flex-shrink: 0;
}
.scene-info { flex: 1; }
.scene-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.scene-hint { font-size: 22rpx; color: var(--text-muted); margin-top: 2rpx; }
.scene-go { font-size: 22rpx; color: var(--text-muted); flex-shrink: 0; opacity: 0.6; }

/* ===== 底部 ===== */
.footer { text-align: center; padding: 40rpx 10rpx; }
.footer-text {
  font-size: 22rpx;
  color: var(--text-muted);
  opacity: 0.7;
}
