/* 新父母急救箱 — 首页样式 */
page {
  background: #FFF8F5;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

.container {
  padding: 24rpx 32rpx 60rpx;
}

/* Hero */
.hero {
  text-align: center;
  padding: 40rpx 16rpx 32rpx;
}
.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D1810;
  line-height: 1.3;
}
.hero-sub {
  font-size: 26rpx;
  color: #8C6E5A;
  margin-top: 12rpx;
  line-height: 1.5;
}

/* 语音提示 */
.voice-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFF0E8, #FFE4D6);
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 32rpx;
  gap: 8rpx;
}
.voice-tip-icon { font-size: 32rpx; }
.voice-tip-text { font-size: 24rpx; color: #B85C3A; }

/* 分类卡片 */
.category-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(141, 100, 74, 0.06);
  overflow: hidden;
}
.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}
.category-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D1810;
}
.category-arrow {
  font-size: 24rpx;
  color: #C4A18A;
  transition: transform 0.2s;
}
.category-arrow.open { transform: rotate(180deg); }

.scene-list { display: none; padding: 0 24rpx 24rpx; }
.scene-list.show { display: block; }

.scene-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-bottom: 8rpx;
  border-radius: 14rpx;
  background: #FFFAF7;
  transition: background 0.15s;
}
.scene-item:active { background: #FFEDE2; }
.scene-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background: #FFF0E8;
  border-radius: 14rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.scene-info { flex: 1; }
.scene-name { font-size: 28rpx; font-weight: 500; color: #3D2010; }
.scene-hint { font-size: 22rpx; color: #B09A8A; margin-top: 4rpx; }
.scene-go { font-size: 24rpx; color: #C4A18A; flex-shrink: 0; }

.footer { text-align: center; padding: 32rpx; }
.footer-text { font-size: 22rpx; color: #C4A18A; }
