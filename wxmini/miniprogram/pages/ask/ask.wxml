<view class="container">

  <!-- 已选场景标签 -->
  <view class="scene-tag">
    <text class="scene-tag-label">{{categoryName}}</text>
    <text class="scene-tag-arrow">→</text>
    <text class="scene-tag-scene">{{sceneName}}</text>
  </view>

  <!-- 孩子选择器 -->
  <view class="child-bar" bindtap="toProfileList">
    <text class="child-bar-icon">{{selectedChild ? (selectedChild.gender === 'boy' ? '👦' : '👧') : '👤'}}</text>
    <view class="child-bar-info" wx:if="{{selectedChild}}">
      <text class="child-bar-name">{{selectedChild.name}}（{{selectedChild.age}}岁）</text>
      <text class="child-bar-tags" wx:if="{{selectedChild.personalityDisplay}}">{{selectedChild.personalityDisplay}}</text>
    </view>
    <view class="child-bar-info" wx:else>
      <text class="child-bar-hint">点击添加孩子档案，让建议更贴合 →</text>
    </view>
    <text class="child-bar-arrow">→</text>
  </view>

  <!-- 提示文字 -->
  <view class="prompt">
    <text class="prompt-text">用语音或文字说说刚才发生了什么，越具体越好。</text>
  </view>

  <!-- 输入区域 -->
  <textarea
    class="input-area"
    value="{{userInput}}"
    placeholder="{{placeholder}}"
    placeholder-style="color:#C4A18A; font-size:28rpx;"
    auto-height
    maxlength="500"
    focus="{{true}}"
    bindinput="onInput"
    adjust-position="{{true}}"
  />

  <!-- 剩余字数 -->
  <view class="char-count">{{userInput.length}}/500</view>

  <!-- 提交按钮 -->
  <button
    class="submit-btn {{submitting ? 'disabled' : ''}}"
    bindtap="submitQuestion"
    disabled="{{submitting}}"
    loading="{{submitting}}"
  >
    {{submitting ? '正在分析…' : '📋 获取建议'}}
  </button>

  <!-- 温馨提示 -->
  <view class="tips">
    <view class="tips-title">💡 小提示</view>
    <view class="tips-item">• 用微信输入法的 🎤 语音输入更快</view>
    <view class="tips-item">• 说清楚时间、地点、孩子说了什么、你说了什么</view>
    <view class="tips-item">• 不用担心写得不完美，AI 能理解大意</view>
  </view>

</view>
