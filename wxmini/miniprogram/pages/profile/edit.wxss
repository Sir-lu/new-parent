/*
 * 档案编辑页 — 添加/修改孩子
 * 设计：表单呼吸感，选项卡片视觉清晰
 */

.container { padding: 24rpx 32rpx 100rpx; }

/* ===== 分区 ===== */
.section { margin-bottom: 36rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 6rpx; }
.section-hint { font-size: 24rpx; color: var(--text-muted); margin-bottom: 16rpx; }

/* ===== 表单 ===== */
.form-group { margin-bottom: 24rpx; }
.label { font-size: 26rpx; color: var(--text-primary); font-weight: 600; display: block; margin-bottom: 12rpx; }
.required { color: var(--color-primary); }

.input {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-shadow: var(--shadow-card);
  border: 2rpx solid transparent;
  transition: border-color 0.3s;
}
.input:focus { border-color: var(--color-primary-light); }

/* ===== 选项 chips ===== */
.option-row { display: flex; flex-wrap: wrap; gap: 14rpx; }
.option-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.option-chip {
  padding: 16rpx 28rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  font-size: 26rpx; color: var(--text-secondary);
  box-shadow: var(--shadow-card);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.option-chip:active { transform: scale(0.96); }
.option-chip.active {
  background: var(--color-primary-ghost);
  color: var(--color-primary-dark);
  border-color: var(--color-primary);
  font-weight: 700;
}

/* ===== 出生年份 ===== */
.birth-row { display: flex; align-items: center; gap: 20rpx; }
.birth-input { width: 220rpx; }
.age-preview {
  font-size: 28rpx; color: var(--color-primary-dark);
  font-weight: 800;
  background: var(--color-primary-ghost);
  padding: 10rpx 24rpx;
  border-radius: var(--radius-md);
}

/* ===== 性格卡片 ===== */
.personality-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 10rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.personality-card:active { transform: scale(0.985); }
.personality-card.active {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, var(--bg-card) 0%, var(--color-primary-ghost) 100%);
}
.personality-check {
  font-size: 34rpx;
  color: var(--text-muted);
  flex-shrink: 0;
  margin-top: 2rpx;
  transition: color 0.2s;
}
.personality-card.active .personality-check { color: var(--color-primary); }
.personality-body { flex: 1; }
.personality-label {
  font-size: 28rpx; font-weight: 600; color: var(--text-primary); display: block;
}
.personality-desc {
  font-size: 22rpx; color: var(--text-muted);
  margin-top: 4rpx; display: block; line-height: 1.45;
}

/* ===== 文本域 ===== */
.textarea {
  width: 100%; min-height: 150rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  font-size: 28rpx; color: var(--text-primary);
  line-height: 1.65;
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.3s;
}
.textarea:focus { border-color: var(--color-primary-light); }
.char-count { text-align: right; font-size: 22rpx; color: var(--text-muted); margin-top: 8rpx; }

/* ===== 提交按钮 ===== */
.submit-btn {
  width: 100%; height: 100rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #FFFFFF; font-size: 32rpx; font-weight: 700;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-button);
  display: flex; align-items: center; justify-content: center;
  margin-top: 24rpx; border: none;
  transition: all 0.2s;
}
.submit-btn:active { transform: scale(0.97); }
.submit-btn.disabled { opacity: 0.5; background: var(--text-muted); }
.submit-btn::after { border: none; }

/* ===== 预览卡片 ===== */
.preview-card {
  margin-top: 32rpx; padding: 28rpx;
  background: var(--bg-card); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}
.preview-title { font-size: 24rpx; color: var(--text-muted); display: block; margin-bottom: 12rpx; }
.preview-line { font-size: 26rpx; color: var(--text-primary); line-height: 1.8; display: block; }
