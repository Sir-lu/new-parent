page { background: #FFF8F5; font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif; }
.container { padding: 24rpx 32rpx 80rpx; }

/* 分区 */
.section { margin-bottom: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #2D1810; margin-bottom: 8rpx; }
.section-hint { font-size: 24rpx; color: #C4A18A; margin-bottom: 16rpx; }

/* 表单 */
.form-group { margin-bottom: 24rpx; }
.label { font-size: 26rpx; color: #3D2010; font-weight: 500; display: block; margin-bottom: 12rpx; }
.required { color: #E8784A; }

.input {
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #2D1810;
  box-shadow: 0 2rpx 8rpx rgba(141, 100, 74, 0.04);
}

/* 选项行 */
.option-row { display: flex; flex-wrap: wrap; gap: 16rpx; }
.option-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.option-chip {
  padding: 16rpx 28rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #8C6E5A;
  box-shadow: 0 2rpx 8rpx rgba(141, 100, 74, 0.04);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.option-chip.active { background: #FFEDE2; color: #B85C3A; border-color: #E8784A; font-weight: 600; }

/* 出生年份 + 年龄 */
.birth-row { display: flex; align-items: center; gap: 20rpx; }
.birth-input { width: 200rpx; }
.age-preview { font-size: 26rpx; color: #B85C3A; font-weight: 600; }

/* 性格卡片 */
.personality-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(141, 100, 74, 0.04);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.personality-card.active { border-color: #E8784A; background: #FFF9F5; }
.personality-check { font-size: 32rpx; color: #C4A18A; flex-shrink: 0; margin-top: 4rpx; }
.personality-card.active .personality-check { color: #E8784A; }
.personality-body { flex: 1; }
.personality-label { font-size: 28rpx; font-weight: 500; color: #2D1810; display: block; }
.personality-desc { font-size: 22rpx; color: #B09A8A; margin-top: 4rpx; display: block; line-height: 1.4; }

/* 文本域 */
.textarea {
  width: 100%;
  min-height: 140rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #2D1810;
  line-height: 1.6;
  box-shadow: 0 2rpx 8rpx rgba(141, 100, 74, 0.04);
  box-sizing: border-box;
}
.char-count { text-align: right; font-size: 22rpx; color: #C4A18A; margin-top: 6rpx; }

/* 提交 */
.submit-btn {
  width: 100%; height: 96rpx;
  background: linear-gradient(135deg, #E8784A, #D4603A);
  color: #FFFFFF; font-size: 32rpx; font-weight: 600;
  border-radius: 48rpx; display: flex; align-items: center; justify-content: center;
  margin-top: 16rpx; border: none;
}
.submit-btn.disabled { opacity: 0.6; }
.submit-btn::after { border: none; }

/* 预览卡片 */
.preview-card {
  margin-top: 32rpx; padding: 24rpx 28rpx;
  background: #FFFFFF; border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(141, 100, 74, 0.05);
}
.preview-title { font-size: 24rpx; color: #C4A18A; display: block; margin-bottom: 12rpx; }
.preview-line { font-size: 26rpx; color: #2D1810; line-height: 1.8; display: block; }
