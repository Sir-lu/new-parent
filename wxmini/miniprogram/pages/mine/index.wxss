page { background: var(--bg-primary); font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif; }
.container { padding: 24rpx 32rpx 80rpx; }

/* ===== 登录卡片 ===== */
.login-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  padding: 48rpx 36rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
  display: block;
}

.login-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-top: 12rpx;
  display: block;
}

.login-btn {
  margin-top: 36rpx;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
}

.login-btn::after { border: none; }

/* ===== 用户卡片 ===== */
.user-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, var(--color-primary-ghost) 0%, var(--color-primary-light) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.user-info { flex: 1; }

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.user-status {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
  display: block;
}

/* ===== 菜单 ===== */
.menu-section {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  gap: 24rpx;
}

.menu-item:active { background: var(--bg-soft); }

.menu-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--color-primary-ghost) 0%, var(--color-primary-light) 100%);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.menu-body { flex: 1; min-width: 0; }

.menu-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
  display: block;
}

.menu-arrow {
  font-size: 36rpx;
  color: var(--text-muted);
  flex-shrink: 0;
  line-height: 1;
}

/* ===== 退出登录 ===== */
.logout-wrap { margin-top: 48rpx; }

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: transparent;
  color: var(--text-muted);
  font-size: 28rpx;
  border: 2rpx solid rgba(143, 171, 189, 0.3);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn::after { border: none; }
