/*
 * 新父母急救箱 — 全局设计系统
 * 美学方向：「冷静薄荷」— 降温、平复、呼吸空间
 *
 * 设计原则：家长打开这个页面时，大概率是生气的、着急的、崩溃的。
 * 颜色必须帮他们降温——蓝色降低心率，冷绿平复焦虑，大量留白创造呼吸感。
 * 这不是温暖的拥抱，这是让人深呼吸的湖边石阶。
 *
 * 融入 Apple HIG 标准：44pt 触控目标、8pt 网格、弹性动效
 */

/* ===== 设计令牌 ===== */
page {
  /* 底色：冷雾白 → 湖冰灰 */
  --bg-primary: #F4F7FA;
  --bg-warm: #F0F4F8;
  --bg-card: #FCFDFE;
  --bg-soft: #F0F3F6;

  /* 主色：沉静湖蓝 — 降低心率、平复情绪 */
  --color-primary: #5B8BA0;
  --color-primary-dark: #4A7A8E;
  --color-primary-light: #CDE3EC;
  --color-primary-ghost: #EBF3F7;

  /* 文字：石墨蓝灰 */
  --text-primary: #263A4A;
  --text-secondary: #5A7A8E;
  --text-muted: #8FABBD;

  /* 辅助色 */
  --color-sage: #7BA08B;       /* 鼠尾草绿 — 自然、安心 */
  --color-lavender: #8E94B8;   /* 冷薰衣紫 — 安抚 */
  --color-ice: #B8D4E3;        /* 冰蓝 — 清爽 */

  /* 圆角系统 — Apple 同心设计 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;

  /* 阴影系统 — 冰冷、浅淡 */
  --shadow-card: 0 1rpx 6rpx rgba(38, 58, 74, 0.03), 0 2rpx 8rpx rgba(38, 58, 74, 0.04);
  --shadow-raised: 0 4rpx 12rpx rgba(38, 58, 74, 0.04), 0 4rpx 8rpx rgba(38, 58, 74, 0.05);
  --shadow-button: 0 4rpx 12rpx rgba(91, 139, 160, 0.18), 0 2rpx 6rpx rgba(91, 139, 160, 0.1);
  --shadow-focus: 0 0 0 6rpx rgba(91, 139, 160, 0.15);

  /* 触控目标 — Apple HIG 最小 44pt = 88rpx */
  --touch-min: 88rpx;
  --touch-comfortable: 96rpx;

  /* 动效 — Apple 弹性缓动 */
  --ease-out: cubic-bezier(0, 0, 0.58, 1);
  --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.275);
  --duration-fast: 0.15s;
  --duration-normal: 0.25s;
  --duration-slow: 0.35s;

  /* 间距 — 基于 8pt 网格 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 40rpx;
  --space-2xl: 48rpx;

  background: var(--bg-primary);
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", "Helvetica Neue", sans-serif;
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
}

/* ===== 基础重置 ===== */
button {
  background: initial;
  padding: 0;
  margin: 0;
  line-height: inherit;
  min-height: var(--touch-min);
  min-width: var(--touch-min);
}
button:focus { outline: 0; }
button::after { border: none; }
button[loading] { opacity: 0.75; }

.tappable {
  min-height: var(--touch-min);
  min-width: var(--touch-min);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tappable:active,
button:active:not([disabled]),
.category-card:active,
.scene-item:active,
.step-card:active,
.personality-card:active {
  transform: scale(0.97);
  transition: transform var(--duration-fast) var(--ease-spring);
}
